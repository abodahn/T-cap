# T-CAP configuration — copy to .env and adjust. All optional; secure defaults apply.

TCAP_ENV=development
# TCAP_SECRET_KEY=            # auto-generated & persisted to instance/.secret_key if unset
TCAP_DEBUG=false
TCAP_PORT=8080

# Admin bootstrap: if unset, a random one-time password is printed to the console
# on first run. Set a strong value to control it.
# TCAP_ADMIN_PASSWORD=

# Seed sample role users (director/agent/exec/... password = Demo@2026)
TCAP_SEED_DEMO=true
# TCAP_DEMO_PASSWORD=Demo@2026

# Language & theme
TCAP_DEFAULT_LANG=en          # en | ar
TCAP_DEFAULT_THEME=dark        # dark | light

# Cookies: keep Secure=true in production (HTTPS). For plain-HTTP local testing:
# TCAP_COOKIE_SECURE=false

TCAP_ORG_NAME=T-GROUP

# --- Email notifications (optional). Blank host = in-app notifications only. ---
# TCAP_SMTP_HOST=smtp.office365.com
# TCAP_SMTP_PORT=587
# TCAP_SMTP_USER=alerts@tgroup.local
# TCAP_SMTP_PASS=
# TCAP_SMTP_FROM=alerts@tgroup.local
# TCAP_SMTP_TLS=true
# Public base URL so emails can link back to the record
# TCAP_PUBLIC_URL=http://10.0.0.5:8080
# Fallback recipients for SLA-breach / stock-low broadcasts (comma-separated)
# TCAP_ALERT_EMAILS=itmanager@tgroup.local,ops@tgroup.local
